#!/usr/bin/env bash
# open-infra CLI — a thin, friendly wrapper over kubectl/Argo for the common loop.
#   open-infra init [app|model|function]  scaffold an infra.yaml (Application / Model / Function)
#   open-infra deploy   validate infra.yaml, render the CR, commit to GitOps
#   open-infra status   show your apps, models, and their health
#   open-infra logs     tail logs for an app
set -euo pipefail

KUBECTL="${KUBECTL:-kubectl}"
command -v "$KUBECTL" >/dev/null 2>&1 || KUBECTL="k3s kubectl"
SELF="open-infra"

usage() { sed -n '2,6p' "$0" | sed 's/^# \{0,1\}//'; }

cmd_init() {
  [ -f infra.yaml ] && { echo "infra.yaml already exists"; exit 0; }
  local kind="${1:-app}"
  local name; name="$(basename "$(pwd)")"
  case "$kind" in
    app|application)
      cat > infra.yaml <<EOF
apiVersion: openinfra.dev/v1
kind: Application
metadata:
  name: ${name}
spec:
  image: ghcr.io/CHANGEME/${name}    # CI replaces the tag on each push
  port: 8080
  scaling: { min: 1, max: 5, targetCPUPercent: 70 }
  domain: ${name}.example            # dev mode rewrites this to sslip.io
  # database: { engine: postgres, name: ${name}db }   # +highAvailability: true for failover
  # storage:  { buckets: [uploads] }
  # queues:   [jobs]
  # secrets:  [chat-model]           # inject a Model endpoint (see: init model)
  env:
    - { name: LOG_LEVEL, value: info }
EOF
      ;;
    model|bedrock|inference)
      cat > infra.yaml <<EOF
apiVersion: openinfra.dev/v1
kind: Model
metadata:
  name: ${name}
spec:
  # Pick from the curated catalog (sets resources + GPU class automatically):
  #   qwen2.5:0.5b, llama3.2:1b  -> nano  (CPU-only, ultra-fast)
  #   llama3.2:3b                -> small (small GPU)
  #   llama3.1:8b                -> standard (small GPU)
  #   mixtral:8x7b               -> large (requires a large GPU)
  model: llama3.1:8b
  # highAvailability: true           # 2 replicas across nodes (degrades if GPUs scarce)
  # domain: ${name}.example          # optional: expose externally (Ingress + TLS)
# An OpenAI-compatible endpoint gated by a generated API key. Apps
# consume it by referencing the secret '${name}-model' in their Application's
# spec.secrets (injects OPENAI_BASE_URL / OPENAI_API_KEY / MODEL). See docs/gpu.md.
EOF
      ;;
    function|fn|serverless)
      cat > infra.yaml <<EOF
apiVersion: openinfra.dev/v1
kind: Function
metadata:
  name: ${name}
spec:
  image: ghcr.io/CHANGEME/${name}    # container that serves HTTP; CI replaces the tag
  port: 8080
  scaling: { min: 0, max: 10 }       # min 0 = scale to zero when idle
  # gpu: 1                           # serverless GPU inference (releases the GPU when idle)
  # queues: [events]                 # event-driven (injects NATS_URL + OPENINFRA_QUEUES)
  # secrets: [api-db-app]            # connect to an app's DB/bucket; functions don't provision state
  env:
    - { name: LOG_LEVEL, value: info }
EOF
      ;;
    *) echo "unknown template '$kind' — use: $SELF init [app|model|function]" >&2; exit 1 ;;
  esac
  echo "wrote infra.yaml (${kind}) — edit it, then: $SELF deploy"
}

cmd_deploy() {
  [ -f infra.yaml ] || { echo "no infra.yaml here — run: $SELF init" >&2; exit 1; }
  echo "validating infra.yaml…"
  # In CI the reusable Action does build+push+commit. Locally we apply directly
  # so you can iterate without a full GitOps round-trip.
  $KUBECTL apply -f infra.yaml
  local name; name="$(awk '/^  name:/{print $2; exit}' infra.yaml)"
  echo "applied Application/$name — track it with: $SELF status"
}

cmd_status() {
  echo "== Applications =="
  $KUBECTL get applications.openinfra.dev -A 2>/dev/null || echo "(none yet)"
  echo; echo "== Models (managed inference) =="
  $KUBECTL get models.openinfra.dev -A 2>/dev/null || echo "(none yet)"
  echo; echo "== Functions (serverless) =="
  $KUBECTL get functions.openinfra.dev -A 2>/dev/null || echo "(none yet)"
  echo; echo "== Argo CD =="
  $KUBECTL -n argocd get applications 2>/dev/null || echo "(Argo not installed)"
}

cmd_logs() {
  local name="${1:-}"; [ -n "$name" ] || { echo "usage: $SELF logs <app>" >&2; exit 1; }
  $KUBECTL logs -l app.kubernetes.io/name="$name" --tail=100 -f
}

case "${1:-}" in
  init)   shift; cmd_init "$@" ;;
  deploy) cmd_deploy ;;
  status) cmd_status ;;
  logs)   shift; cmd_logs "$@" ;;
  ""|-h|--help) usage ;;
  *) echo "unknown command: $1" >&2; usage; exit 1 ;;
esac
